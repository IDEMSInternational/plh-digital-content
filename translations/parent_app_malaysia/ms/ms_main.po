msgctxt "global"
msgid ""
"**Hello! My name is @fields.facilitator_name. I’m so glad you’re here!**\n"
"\n"
"I’ll be helping you learn using @global.app_name! In the next few steps, I’ll ask you a few questions, so that I can make your learning experience just right for you!"
msgstr ""
"**Helo! Saya @fields.facilitator_name. Terima kasih kerana berada di sini.**\n"
"\n"
"Saya akan menemani anda belajar melalui @global.app_name. Sebentar lagi, saya akan tanya beberapa soalan supaya pembelajaran anda dapat disesuaikan mengikut keperluan anda!"

#. type=global
msgctxt "global"
msgid "What is your relationship status?"
msgstr "Apakah status hubungan anda?"

#. type=global
msgctxt "global"
msgid "Select relationship status"
msgstr "Pilih status hubungan"

#. type=global
msgctxt "global"
msgid "What is your ethnicity?"
msgstr "Apakah kaum/etnik anda?"

#. type=global
msgctxt "global"
msgid "Select ethnicity"
msgstr "Pilih kaum/etnik"

#. type=global
msgctxt "global"
msgid "How many children do you care for in your home?"
msgstr "Berapakah orang anak yang berada dalam jagaan anda di rumah?"

#. type=global
msgctxt "global"
msgid "Enter number of children"
msgstr "Berikan bilangan anak"

#. type=global
msgctxt "global"
msgid "Please enter a number between 1 and 20."
msgstr "Sila berikan nombor di antara 1 dan 20."

#. type=global
msgctxt "global"
msgid ""
"**Let’s get started!**\n"
" \n"
"Can you tell me a little about yourself?"
msgstr ""
"**Jom kita mulakan!**\n"
"\n"
"Boleh kongsikan sedikit tentang diri anda?"

#. type=global
msgctxt "global"
msgid "What is your name?"
msgstr "Siapakah nama anda?"

#. type=global
msgctxt "global"
msgid "What is your gender?"
msgstr "Apakah jantina anda?"

#. type=global
msgctxt "global"
msgid "Where do you live?"
msgstr "Di manakah anda tinggal?"

#. type=global
msgctxt "global"
msgid "Select location"
msgstr "Pilih lokasi"

#. type=global
msgctxt "global"
msgid "What is your child's name?"
msgstr "Siapakah nama anak anda?"

#. type=global
msgctxt "global"
msgid "Enter name"
msgstr "Berikan nama"

#. type=global
msgctxt "global"
msgid "Is your child a girl or a boy?"
msgstr "Adakah anak anda seorang perempuan atau lelaki?"

#. type=global
msgctxt "global"
msgid "Select gender"
msgstr "Pilih jantina"

#. type=global
msgctxt "global"
msgid "Enter age"
msgstr "Berikan umur"

#. type=global
#. The string @global.app_name should not be translated.
msgctxt "global"
msgid "@global.app_name only supports parents of children between 2 and 7."
msgstr "@global.app_name hanya menyokong ibu bapa kepada anak berumur antara 2 hingga 7 tahun."

#. type=template
msgctxt "template"
msgid "What you need"
msgstr "Apa yang anda perlukan"

#. type=template
msgctxt "template"
msgid "Steps"
msgstr "Langkah-langkah"

#. type=template
msgctxt "template"
msgid "More tips"
msgstr "Tip tambahan"

#. type=template
msgctxt "template"
msgid "Try also"
msgstr "Sila cuba juga"

#. type=template
msgctxt "template"
msgid "Submit"
msgstr "Hantar"

#. type=template
msgctxt "template"
msgid "Tap and type"
msgstr "Klik dan taip"

#. type=template
#. The string @local.submit should not be translated.
msgctxt "template"
msgid "To launch the app in developer mode, enter your developer code in the box below and press @local.submit."
msgstr "Masukkan kod pembangun dalam kotak di bawah dan tekan @local.submit untuk melancarkan aplikasi dalam mod pembangun."

#. type=template
msgctxt "template"
msgid "You have entered an incorrect code."
msgstr "Kod yang anda masukkan tidak betul."

#. type=template
msgctxt "template"
msgid "This code is correct."
msgstr "Kod ini adalah betul."

#. type=template
msgctxt "template"
msgid "Enter developer mode"
msgstr "Memasuki mod pembangun"

#. type=template
#. The string @global.app_name should not be translated.
msgctxt "template"
msgid "@global.app_name has downloaded an update. Please restart the app to finish installation."
msgstr "@global.app_name telah memuat turun satu kemas kini. Untuk menyelesaikan pemasangan, sila mulakan semula aplikasi."

#. type=template
msgctxt "template"
msgid "Restart"
msgstr "Mula semula"

#. type=template
#. The string @local.countdown_days should not be translated.
msgctxt "template"
msgid "Countdown days: @local.countdown_days"
msgstr "Bilangan hari: @local.countdown_days"

#. type=template
msgctxt "template"
msgid "Choose a number of days to count down"
msgstr "Pilih bilangan hari untuk dikira"

#. type=template
msgctxt "template"
msgid "Save"
msgstr "Simpan"

#. type=template
msgctxt "template"
msgid "Copy code"
msgstr "Salin kod"

#. type=template
msgctxt "template"
msgid "Copied!"
msgstr "Disalin!"


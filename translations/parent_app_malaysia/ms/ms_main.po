msgstr "Last sync at: @local.sync_latest"

#. type=template
msgctxt "template"
msgid "This device has never been synced. Sync to reveal your code."
msgstr "Peranti/gajet ini belum pernah synced. Sync untuk melihat kod anda."

#. type=template
msgctxt "template"
msgid "Sync now"
msgstr "Sync now"

#. type=template
msgctxt "template"
